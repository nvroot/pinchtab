#!/usr/bin/env bash
set -euo pipefail

# pdev — Pinchtab developer toolkit
# Usage: pdev [command] [sub]    Run a command directly
#        pdev                    Interactive picker

cd "$(dirname "$0")"

BOLD=$'\033[1m'
ACCENT=$'\033[38;2;251;191;36m'
MUTED=$'\033[38;2;90;100;128m'
SUCCESS=$'\033[38;2;0;229;204m'
ERROR=$'\033[38;2;230;57;70m'
NC=$'\033[0m'

# ── Commands ─────────────────────────────────────────────────────────
# name:emoji:description
COMMANDS=(
  "check:🧪:All checks (Go + Dashboard)"
  "  check go:🧪:Go only"
  "  check dashboard:🧪:Dashboard only"
  "build:🚀:Build & run server + dashboard"
  "doctor:🩺:Setup dev environment"
  "security:🔒:Gosec security scan"
  "docs:📖:Validate docs JSON"
  "hooks:🪝:Install git hooks"
)

# ── Helpers ──────────────────────────────────────────────────────────

show_help() {
  echo ""
  echo "  ${ACCENT}${BOLD}🦀 Pinchtab Dev${NC}"
  echo ""
  for cmd in "${COMMANDS[@]}"; do
    IFS=':' read -r name emoji desc <<< "$cmd"
    if [[ "$name" == " "* ]]; then
      local trimmed="${name#"${name%%[![:space:]]*}"}"
      printf "      ${BOLD}%-18s${NC} ${MUTED}%s${NC}\n" "$trimmed" "$desc"
    else
      printf "  ${SUCCESS}%s${NC} ${BOLD}%-18s${NC} ${MUTED}%s${NC}\n" "$emoji" "$name" "$desc"
    fi
  done
  echo ""
  echo "  ${MUTED}Usage: pdev [command] [sub]${NC}"
  echo ""
}

run_command() {
  local target="$1"

  echo ""

  case "$target" in
    "check")
      echo "  ${ACCENT}${BOLD}🧪 Running all checks (Go + Dashboard)${NC}"
      echo ""
      bash scripts/check.sh
      local go_exit=$?
      echo ""
      echo "  ${ACCENT}${BOLD}🧪 Dashboard checks${NC}"
      echo ""
      bash scripts/check-dashboard.sh
      local dash_exit=$?
      if [ $go_exit -ne 0 ] || [ $dash_exit -ne 0 ]; then exit 1; fi
      exit 0
      ;;
    "check go")
      echo "  ${ACCENT}${BOLD}🧪 Go checks${NC}"
      echo ""
      exec bash scripts/check.sh
      ;;
    "check dashboard")
      echo "  ${ACCENT}${BOLD}🧪 Dashboard checks${NC}"
      echo ""
      exec bash scripts/check-dashboard.sh
      ;;
    "build")        exec bash scripts/dev.sh ;;
    "doctor")       exec bash scripts/doctor.sh ;;
    "security")     exec bash scripts/check-gosec.sh ;;
    "docs")         exec bash scripts/check-docs-json.sh ;;
    "hooks")        exec bash scripts/install-hooks.sh ;;
    *)
      echo "  ${ERROR}Unknown command: $target${NC}"
      show_help
      exit 1
      ;;
  esac
}

pick_with_gum() {
  local options=()
  for cmd in "${COMMANDS[@]}"; do
    IFS=':' read -r name emoji desc <<< "$cmd"
    options+=("$emoji  $name — $desc")
  done

  local choice
  choice=$(printf '%s\n' "${options[@]}" | gum choose \
    --header "🦀 Pinchtab Dev" \
    --header.foreground "#fbbf24" \
    --cursor.foreground "#00e5cc" \
    --selected.foreground "#00e5cc")

  # Extract command name from choice (between emoji+spaces and " —")
  local picked
  picked=$(echo "$choice" | sed 's/^.*  //' | sed 's/ —.*//')
  run_command "$picked"
}

pick_with_select() {
  echo ""
  echo "  ${ACCENT}${BOLD}🦀 Pinchtab Dev${NC}"
  echo ""

  local names=()
  local i=1
  for cmd in "${COMMANDS[@]}"; do
    IFS=':' read -r name emoji desc <<< "$cmd"
    local trimmed="${name#"${name%%[![:space:]]*}"}"
    if [[ "$name" == " "* ]]; then
      printf "  ${MUTED}[%d]${NC}     ${BOLD}%-18s${NC} %s\n" "$i" "$trimmed" "$desc"
    else
      printf "  ${MUTED}[%d]${NC} ${SUCCESS}%s${NC} ${BOLD}%-18s${NC} %s\n" "$i" "$emoji" "$trimmed" "$desc"
    fi
    names+=("$trimmed")
    i=$((i + 1))
  done

  echo ""
  echo -ne "  ${BOLD}Pick [1-${#COMMANDS[@]}]:${NC} "
  read -r choice

  # Handle numeric or name input
  if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le ${#COMMANDS[@]} ]; then
    run_command "${names[$((choice - 1))]}"
  else
    run_command "$choice"
  fi
}

# ── Main ─────────────────────────────────────────────────────────────

# Direct command with optional subcommand
if [ $# -gt 0 ]; then
  case "$1" in
    -h|--help|help) show_help; exit 0 ;;
    check)
      if [ $# -gt 1 ]; then
        run_command "check $2"
      else
        run_command "check"
      fi
      ;;
    *) run_command "$1" ;;
  esac
fi

# Interactive picker
if command -v gum &>/dev/null; then
  pick_with_gum
else
  pick_with_select
fi
